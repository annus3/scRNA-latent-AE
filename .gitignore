# .gitignore

# Datasets & Processed Data
data/*
!data/.gitkeep

# Experiment Outputs
results/*
!results/.gitkeep
checkpoints/*
!checkpoints/.gitkeep

# Jobs, Logs & TensorBoard
logs/*
!logs/.gitkeep
*.log
*.out
*.err
slurm-*.out
slurm-*.err
logs/
jobs/*
!jobs/slurm_sweep_generic.sh 
checkpoints/
docs/

# Python Cache/Build Files
__pycache__/
*.py[cod]
*$py.class
*.so
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Jupyter Notebook
.ipynb_checkpoints

# IDEs & OS Files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Type Hinting & Testing
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/

