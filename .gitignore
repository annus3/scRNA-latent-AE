# Logs & TensorBoard events
logs/*
!logs/.gitkeep

# SLURM output files
slurm-*.out
slurm-*.err
*.out
*.err
*.log

# Internal docs & notebooks (not for public repo)
docs/
notebooks/
config/tmp/

